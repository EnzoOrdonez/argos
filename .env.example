# =====================================================
# ARGOS — Environment Variables Template
# =====================================================
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to git. It's already in .gitignore.
# This .env.example is the public template — keep it free of secrets.
#
# =====================================================


# ----------- Project metadata -----------
PROJECT_NAME=argos
ENVIRONMENT=development  # development | staging | production
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR


# ----------- Wazuh -----------
# Wazuh manager API endpoint
WAZUH_API_URL=https://wazuh-manager.lab.local:55000
WAZUH_API_USER=wazuh-api-user
WAZUH_API_PASSWORD=replace-with-secure-password
WAZUH_VERIFY_SSL=false  # true in production


# ----------- OpenSearch -----------
OPENSEARCH_URL=https://opensearch.lab.local:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=replace-with-secure-password
OPENSEARCH_VERIFY_SSL=false


# ----------- Redis (state + queues) -----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=  # leave empty for local dev, required in production
REDIS_DB=0


# ----------- LLM Triage (Layer 4) -----------
# Backend selection: deepseek | qwen
LLM_BACKEND=deepseek

# DeepSeek API (primary)
# Get key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-replace-with-real-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Qwen API (fallback)
# Get key at: https://dashscope.console.aliyun.com/
QWEN_API_KEY=sk-replace-with-real-key
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen2.5-72b-instruct

# LLM operational limits
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_DAILY_BUDGET_USD=5.00  # hard cutoff per day to prevent runaway costs


# ----------- Approval flow (ADR-0003 / ADR-0006) -----------
# JWT signing for approval URLs
JWT_SECRET=replace-with-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=5

# Approval timeout configuration
APPROVAL_T2_TIMEOUT_SECONDS=180  # 3 minutes
APPROVAL_CONSOLIDATION_WINDOW_SECONDS=60  # for split-brain resolution

# Throttle parameters during T2 countdown
THROTTLE_CPU_PERCENT_LIMIT=10
THROTTLE_IO_PRIORITY=idle


# ----------- SMTP (email notifications) -----------
# For local dev use MailHog: docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=argos-noreply@lab.local
SMTP_USE_TLS=false  # true in production


# ----------- Notification recipients (configurable per ADR-0005) -----------
# Comma-separated list of approver emails
# In production, this would be loaded from config/recipients.yaml
APPROVER_EMAILS=p1@demo.local,p2@demo.local,p3@demo.local,p4@demo.local


# ----------- FastAPI services -----------
# Decision Engine API
DECISION_ENGINE_HOST=0.0.0.0
DECISION_ENGINE_PORT=8001

# LLM Triage API
LLM_TRIAGE_HOST=0.0.0.0
LLM_TRIAGE_PORT=8002

# Approval API (public-facing for email button clicks)
APPROVAL_API_HOST=0.0.0.0
APPROVAL_API_PORT=8003
APPROVAL_API_PUBLIC_URL=http://localhost:8003  # used in email links


# ----------- Streamlit dashboards -----------
STREAMLIT_PORT=8501
STREAMLIT_AUTH_ENABLED=false  # true in production


# ----------- Observability / Metrics -----------
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090


# ----------- Lab configuration -----------
LAB_VICTIM_WINDOWS_IP=10.0.0.21
LAB_VICTIM_LINUX_IP=10.0.0.22
LAB_MANAGER_IP=10.0.0.10
LAB_NETWORK_SUBNET=10.0.0.0/24


# ----------- Demo mode -----------
# Set to true during demo to use cached LLM responses for known scenarios
# Reduces dependency on external LLM API during exposition
DEMO_MODE=false
DEMO_CACHE_PATH=./demo/cached-responses
