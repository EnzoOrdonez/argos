# =====================================================
# ARGOS — Environment Variables Template
# =====================================================
#
# Copia este archivo a .env y completa con valores reales:
#   cp .env.example .env
#
# NUNCA commitees .env al git. Ya está en .gitignore.
# Este .env.example es la plantilla pública — debe permanecer libre de secretos.
#
# =====================================================


# ----------- Project metadata -----------
PROJECT_NAME=argos
ENVIRONMENT=development  # development | test | staging | production
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR


# ----------- Wazuh -----------
WAZUH_API_URL=https://wazuh-manager.lab.local:55000
WAZUH_API_USER=wazuh-api-user
WAZUH_API_PASSWORD=replace-with-secure-password
WAZUH_VERIFY_SSL=false  # true en producción


# ----------- OpenSearch -----------
OPENSEARCH_URL=https://opensearch.lab.local:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=replace-with-secure-password
OPENSEARCH_VERIFY_SSL=false


# ----------- Redis (state + queues) -----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=  # vacío en dev local; obligatorio en producción
REDIS_DB=0


# ----------- PostgreSQL de AUDITORIA (argos_audit, servicio del docker-compose) -----------
# C11 (2026-06-29): estas POSTGRES_* las consume el servicio `postgres` del compose
# (el log de ARGOS, en el core). NO es el PG victima (ver VICTIM_PG_* abajo).
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=argos_audit
POSTGRES_USER=argos
POSTGRES_PASSWORD=replace-with-secure-password
# DSN del audit SQL. Lo consumen: el sink PostgresSink (scripts/demo_injector.py) para
# ESCRIBIR eventos, y la consola web (:8080) para LEER el timeline de auditoría. Sin
# setear, la consola sigue funcionando (solo Redis), pero sin el card de timeline.
ARGOS_AUDIT_SQL_DSN=postgresql://argos:replace-with-secure-password@postgres:5432/argos_audit
# Timeout de conexión del sink de auditoría (entero, 1..60). El constructor no
# conecta; el primer evento intenta conectar con este límite y registra pérdidas.
ARGOS_AUDIT_SQL_CONNECT_TIMEOUT_SECONDS=5

# Auth de la consola web (RF-7/HU-6): credencial compartida HTTP Basic que gatea `/` y
# `/api/*` (`/health` queda abierto). Sin setear AMBAS, la consola corre SIN auth (dev en
# localhost). Setealas antes de exponer la consola más allá de localhost.
CONSOLE_BASIC_USER=admin
CONSOLE_BASIC_PASS=replace-with-console-password

# ----------- PostgreSQL VICTIMA (activo defendido — VM Debian .21, ADR-0009) -----------
# DB app_prod / schema intibank. La crea lab/provision/postgres-seed.sql (DDL ADR-0009 §2.2).
# La usan los simuladores de ataque (UC-04/07/08), no el core de ARGOS.
VICTIM_PG_HOST=192.168.56.21
VICTIM_PG_PORT=5432
VICTIM_PG_DB=app_prod
VICTIM_PG_SCHEMA=intibank
VICTIM_PG_USER=inti_app
VICTIM_PG_PASSWORD=inti_app_secret_2026          # rol app ADR-0009 §2.4 (credencial solo-lab)
POSTGRES_DUMP_PATH=/var/backups/postgres


# ----------- LLM Triage (Layer 4 · ADR-0001 v2) -----------
# Backend selection: openai | llama_local
LLM_BACKEND=openai

# Endpoint OpenAI-compatible. Fase 4 (ADR-0001): NVIDIA NIM. El cliente de llm_triage
# lee base_url/key/modelo de estas vars. La key real va en .env, NUNCA acá.
# Crear key: https://build.nvidia.com (NVIDIA)  |  https://platform.openai.com/api-keys (OpenAI)
OPENAI_API_KEY=nvapi-replace-with-real-key
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=openai/gpt-oss-120b                   # primario (C10: rapido/fiable; el id requiere prefijo openai/)
OPENAI_FALLBACK_MODEL=moonshotai/kimi-k2.6         # fallback si el primario falla

# Huérfanas (2026-07-01): backends descartados (deepseek-v4-pro, evaluación de kimi/minimax
# como primario). Ningún .py del repo las lee — openai_client.py:65 solo lee OPENAI_API_KEY.
# No hace falta completarlas para reproducir nada. Se dejan comentadas para no confundir a
# quien clona el repo (ver deploy/README.md).
# MiniMax_M3_API_KEY=
# Kimi2_6_API_KEY=
# DeepSeek_V4_PRO_API_KEY=

# Llama 3.1 8B local vía Ollama (fallback, zero-egress)
# Instalación: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
LLAMA_MODEL=llama3.1:8b

# Límites operacionales del LLM
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_DAILY_BUDGET_USD=5.00  # hard cutoff diario para evitar costos runaway


# ----------- Executor (ADR-0015 §2.1) -----------
# Conmuta el ResponseExecutor de la contención: 'simulated' (solo development/test,
# nunca toca una VM) o 'wazuh' (active-response real vía el manager). Si =wazuh
# y faltan las WAZUH_API_* de arriba, el servicio no arranca (fail-closed).
ARGOS_EXECUTOR=simulated  # simulated|wazuh

# Safety rail explícito (RF-4): con 'true' (default en install nuevo) NINGUNA acción de
# contención se auto-ejecuta sin aprobación humana, ni siquiera T0/T1 — supera la
# matemática de tiers y el failsafe de timeout. Lo lee el daemon consumer
# (python -m soar.decision_engine / servicio soar-consumer del compose).
ARGOS_REQUIRE_APPROVAL=true

# ----------- Approval flow (ADR-0003 / ADR-0006) -----------
# JWT signing de los botones de aprobación (ADR-0010 §4.4).
# Sin secreto configurado, los votos Telegram quedan deshabilitados.
# El algoritmo está pinneado a HS256 en código (RFC 8725 §3.1): no es configurable.
ARGOS_JWT_SECRET=
JWT_EXPIRATION_MINUTES=5

# Timeouts
APPROVAL_T2_TIMEOUT_SECONDS=180  # 3 minutos
APPROVAL_CONSOLIDATION_WINDOW_SECONDS=60  # split-brain resolution
APPROVAL_CALLBACK_TTL_SECONDS=300

# Inventario de criticidad por host (decide el two-person rule, ADR-0003/0013 §2.3).
# Sin setear: usa los 4 hosts embebidos del lab (soar/inventory.py). Para otro entorno,
# apuntar a un JSON keyed by host_id (ver config/host_inventory.example.json). El archivo
# REEMPLAZA los defaults; un archivo malformado falla al arrancar (no degrada en silencio).
# ARGOS_HOST_INVENTORY=config/host_inventory.json

# Mapeo grupo-de-regla-Wazuh -> capa de detección del bridge (RF-2/HU-7). Sin setear:
# usa los defaults embebidos (argos_layer1 -> layer_1, argos_layer3 -> layer_3). Para
# reconocer grupos nativos de Wazuh (p.ej. authentication_failures -> layer_1) sin tocar
# código, apuntar a un JSON {"grupo": "layer_1"} (ver config/bridge_group_map.example.json).
# REEMPLAZA los defaults; un archivo malformado falla al arrancar el bridge.
# ARGOS_BRIDGE_GROUP_MAP=config/bridge_group_map.json

# Throttle parameters durante el countdown T2
THROTTLE_CPU_PERCENT_LIMIT=10
THROTTLE_IO_PRIORITY=idle


# ----------- Notification channels (ADR-0007 v2) -----------

# --- Telegram (PRIMARIO · t=0) ---
# Crear bot con @BotFather, obtener bot_token
TELEGRAM_BOT_TOKEN=
# Chat receptor, usuarios individuales autorizados y secreto configurado en setWebhook.
TELEGRAM_CHAT_ID=
TELEGRAM_APPROVER_USER_IDS=
TELEGRAM_WEBHOOK_SECRET=

# --- Discord (VISIBILIDAD DEL EQUIPO · t=0) ---
# Crear webhook en el server del equipo (Server Settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=
# Role ID para @-mention agresivo a todos los aprobadores
DISCORD_APPROVERS_ROLE_ID=

# --- Twilio Voice DTMF (ESCALACIÓN · t=60s) ---
# Trial gratis: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_APPROVER_PHONES=  # E.164 format, separados por coma
# Destinatario efectivo del canal de voz en esta etapa (un aprobador).
TWILIO_TO_NUMBER=
TWILIO_MONTHLY_COST_CAP_USD=5

# --- Email (POST-FACTO SUMMARY · nunca en path crítico) ---
# Para dev local usar MailHog: docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=argos-noreply@lab.local
SMTP_USE_TLS=false  # true en producción
APPROVER_EMAILS=enzo@demo.local,sebastian@demo.local,angeles@demo.local,diego@demo.local


# ----------- FastAPI services -----------
# Decision Engine API
DECISION_ENGINE_HOST=0.0.0.0
DECISION_ENGINE_PORT=8001

# LLM Triage API
LLM_TRIAGE_HOST=0.0.0.0
LLM_TRIAGE_PORT=8002
# Timeout del hook SOAR->POST /triage (lado decision_engine). OJO: es DISTINTO de
# LLM_REQUEST_TIMEOUT_SECONDS de arriba (ese es llm_triage->NVIDIA). Corto a propósito:
# el enriquecimiento LLM nunca demora la espera HITL (R-2). Default 5.0 si no se setea.
LLM_TRIAGE_TIMEOUT_SECONDS=5.0

# Approval API (public-facing para clicks de aprobación)
APPROVAL_API_HOST=0.0.0.0
APPROVAL_API_PORT=8003
APPROVAL_API_PUBLIC_URL=http://localhost:8003


# ----------- Streamlit dashboards -----------
STREAMLIT_PORT=8501
STREAMLIT_AUTH_ENABLED=false  # true en producción


# ----------- Lab configuration -----------
LAB_VICTIM_WINDOWS_IP=192.168.56.20
LAB_VICTIM_LINUX_IP=192.168.56.21
LAB_MANAGER_IP=192.168.56.10
LAB_NETWORK_SUBNET=192.168.56.0/24


# ----------- Demo mode -----------
# true durante demo en vivo para usar respuestas cacheadas del LLM
# Reduce dependencia del API externo durante la exposición
# IMPORTANTE para reproducir Track B (docker-compose + demo_injector): poner esto en
# true. Neutraliza BUG-1 (timeout de 5s del hook SOAR->llm_triage) usando las 3
# respuestas ya cacheadas en demo/cached-responses/ (T1078/T1083/T1190), que SÍ están
# trackeadas en git y sobreviven un clone limpio.
DEMO_MODE=false
DEMO_CACHE_PATH=./demo/cached-responses
