        <mxCell id="flow_box" value="FLUJO (numeración de las flechas)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1;fontSize=12;fillColor=#ffffff;strokeColor=#666666;align=left;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
