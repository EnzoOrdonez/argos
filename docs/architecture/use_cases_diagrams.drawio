<mxCell id="u1-4" value="🧠  &lt;b&gt;Layer 2 ML scoring (en paralelo)&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;Shannon entropy = 7.9 · files_touched_per_min = 1500&lt;br/&gt;IsoForest + OC-SVM: is_anomaly=True · confidence = 0.94&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
