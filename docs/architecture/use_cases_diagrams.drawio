<mxCell id="u4-legend" value="📖  Leyenda · Timers (orden cronológico)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#999;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
  <mxGeometry x="80" y="715" width="1560" height="230" as="geometry" />
</mxCell>
<mxCell id="u4-leg-1" value="&lt;b&gt;t = 0&lt;/b&gt; — Incident creado&lt;br/&gt;• Sigma + ML disparan&lt;br/&gt;• Tier T2 asignado&lt;br/&gt;• &lt;b&gt;Throttle preventivo&lt;/b&gt; aplicado (limita queries/s del atacante)&lt;br/&gt;• Telegram + Discord enviados a 4 aprobadores&lt;br/&gt;• Streamlit Console muestra incident T2" style="text;html=1;align=left;fontSize=11;fontColor=#333;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
  <mxGeometry x="100" y="750" width="360" height="180" as="geometry" />
</mxCell>
<mxCell id="u4-leg-2" value="&lt;b&gt;t = 60 s&lt;/b&gt; — Escalación voz&lt;br/&gt;• Si &lt;b&gt;nadie&lt;/b&gt; respondió → Twilio llama a los 4 celulares&lt;br/&gt;• Captura DTMF: 1 = approve, 2 = reject&lt;br/&gt;• Si alguien YA respondió, &lt;b&gt;no se llama&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;(la ventana de 60 s consolidation ya está corriendo)" style="text;html=1;align=left;fontSize=11;fontColor=#333;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
  <mxGeometry x="470" y="750" width="360" height="180" as="geometry" />
</mxCell>
<mxCell id="u4-leg-3" value="&lt;b&gt;Ventana de 60 s consolidation&lt;/b&gt;&lt;br/&gt;• Se abre con la &lt;b&gt;primera&lt;/b&gt; respuesta (no a t=0)&lt;br/&gt;• Durante esa ventana captura respuestas adicionales&lt;br/&gt;• Al cerrar evalúa quorum&lt;br/&gt;• Si solo 1 respondió → no hay quorum → espera 180 s" style="text;html=1;align=left;fontSize=11;fontColor=#333;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
  <mxGeometry x="840" y="750" width="360" height="180" as="geometry" />
</mxCell>
<mxCell id="u4-leg-4" value="&lt;b&gt;t = 180 s&lt;/b&gt; — Hard timeout (ADR-0003 Q9)&lt;br/&gt;• Production-critical + two-person → &lt;b&gt;block&lt;/b&gt; (no auto-execute)&lt;br/&gt;• Throttle rollback&lt;br/&gt;• Notif a equipo: &quot;incident X cerrado por timeout sin quorum&quot;&lt;br/&gt;• Decisión registrada con policy=no_quorum_timeout en audit log" style="text;html=1;align=left;fontSize=11;fontColor=#333;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
  <mxGeometry x="1210" y="750" width="420" height="180" as="geometry" />
</mxCell>
  </root>
</mxGraphModel>
</diagram>
<diagram id="uc-06" name="UC-06 DDoS T1">
<mxGraphModel dx="1700" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="900" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />
<mxCell id="title" value="UC-06 — DDoS (T1 auto-throttle reversible)" style="text;html=1;align=center;fontSize=22;fontStyle=1;fontColor=#0a3d62;" vertex="1" parent="1">
  <mxGeometry x="380" y="15" width="940" height="32" as="geometry" />
</mxCell>
<mxCell id="subtitle" value="hping3 SYN flood / slowhttptest · Layer 1 Sigma red · severity=HIGH → T1 · acción reversible automática · sin HITL" style="text;html=1;align=center;fontSize=11;fontColor=#5f6c7b;fontStyle=2;" vertex="1" parent="1">
  <mxGeometry x="380" y="50" width="940" height="22" as="geometry" />
</mxCell>
<mxCell id="u6-1" value="🎯  &lt;b&gt;Atacante externo&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;sudo hping3 -S --flood -p 80 192.168.56.21&lt;br/&gt;O: slowhttptest -c 1000 -B -t POST -u http://...&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="120" y="100" width="460" height="90" as="geometry" />
</mxCell>
<mxCell id="u6-2" value="🌐  &lt;b&gt;linux-victim — capa de red saturada&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;SYN queue desbordándose · connections in TIME_WAIT&lt;br/&gt;servicio HTTP responde con timeout o 503&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="120" y="220" width="460" height="90" as="geometry" />
</mxCell>
<mxCell id="u6-3" value="🛡️  &lt;b&gt;Sigma Layer 1 — reglas de red firing&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;✓ T1498 Network Denial of Service&lt;br/&gt;✓ T1499 Endpoint Denial of Service (slow HTTP)&lt;br/&gt;Wazuh detecta tasa SYN/s anómala vs baseline&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="120" y="340" width="460" height="100" as="geometry" />
</mxCell>
<mxCell id="u6-4" value="⚙️  &lt;b&gt;SOAR Decision Engine → Tier T1&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;severity = HIGH → SEVERITY_TO_BASE_TIER[HIGH] = T1&lt;br/&gt;num_layers_fired = 1 (sólo Layer 1 red)&lt;br/&gt;técnica T1498 NO está en AUTO_T0 → no escala a T0&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="120" y="470" width="460" height="100" as="geometry" />
</mxCell>
<mxCell id="u6-5a" value="⚡  &lt;b&gt;ACCIÓN AUTOMÁTICA&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;Wazuh API rate-limit / iptables&lt;br/&gt;DROP source IP&lt;br/&gt;(reversible · no isolate completo)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="75" y="600" width="220" height="80" as="geometry" />
</mxCell>
<mxCell id="u6-5b" value="🔔  &lt;b&gt;Notif&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;Telegram&lt;br/&gt;Discord&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="305" y="600" width="130" height="80" as="geometry" />
</mxCell>
<mxCell id="u6-5c" value="📊  &lt;b&gt;Audit log&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;PostgreSQL&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="445" y="600" width="135" height="80" as="geometry" />
</mxCell>
<mxCell id="u6-6" value="✅  &lt;b&gt;OUTCOME: tráfico fuente bloqueado · servicio recupera disponibilidad en &lt;25 s&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#15803d;fontSize=13;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="120" y="710" width="460" height="50" as="geometry" />
</mxCell>
