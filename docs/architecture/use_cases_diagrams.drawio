<mxCell id="u4-1" value="🎯  &lt;b&gt;Atacante&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;postgres_attack.py&lt;br/&gt;target linux-victim&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="80" y="95" width="280" height="70" as="geometry" />
</mxCell>
<mxCell id="u4-2" value="⭐  &lt;b&gt;PostgreSQL :5432&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;ACTIVO DEFENDIDO&lt;br/&gt;criticality=production-critical&lt;br/&gt;pgAudit registra cada query&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="80" y="195" width="280" height="90" as="geometry" />
</mxCell>
<mxCell id="u4-3" value="🛡️🧠  &lt;b&gt;Detection (Layer 1 + 2)&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;Sigma: T1190 (web SQLi pattern) + T1078 (anomalous user)&lt;br/&gt;ML: query rate spike · row count outlier&lt;br/&gt;num_layers_fired = 2 · confidence = 0.74&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="80" y="315" width="280" height="100" as="geometry" />
</mxCell>
<mxCell id="u4-4" value="⚙️  &lt;b&gt;SOAR → Tier T2 (two-person)&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;severity=MEDIUM, T2 base&lt;br/&gt;target.tags incluye production-critical&lt;br/&gt;→ Two-Person Rule activa&lt;br/&gt;⚡ Throttle preventivo aplicado (reversible)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="80" y="445" width="280" height="110" as="geometry" />
</mxCell>
<mxCell id="u4-5a" value="🔔  Telegram + Discord a 4 aprobadores ([Approve][Reject])" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="80" y="590" width="280" height="50" as="geometry" />
</mxCell>
<mxCell id="u4-5b" value="📞  Twilio voz se dispara a t=60s si nadie respondió aún (no es 'fin' — es escalación)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9e6;strokeColor=#b58e1a;fontSize=10;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="80" y="650" width="280" height="50" as="geometry" />
</mxCell>
<mxCell id="u4-tl" value="⏱  Línea de tiempo  ·  t=0 (incident creado) ────► t=60s (Twilio) ────► t=180s (hard timeout)" style="text;html=1;align=center;fontSize=12;fontColor=#b58e1a;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="410" y="100" width="1230" height="22" as="geometry" />
</mxCell>
<mxCell id="u4-approvers" value="👥  Aprobadores HITL (4 integrantes · multi-canal)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9e6;strokeColor=#d6b656;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
  <mxGeometry x="410" y="130" width="1230" height="260" as="geometry" />
</mxCell>
<mxCell id="u4-p1" value="📱  &lt;b&gt;P1 Enzo&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;Telegram + Twilio fallback&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
