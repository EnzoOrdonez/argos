<mxCell id="u1-3" value="🛡️  &lt;b&gt;Wazuh Manager → Sigma Layer 1 dispara 3 reglas&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;✓ T1486 (Data Encrypted for Impact)&lt;br/&gt;✓ T1490 (Inhibit System Recovery)&lt;br/&gt;✓ T1083 (File Discovery)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
