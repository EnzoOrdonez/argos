  <mxGeometry x="740" y="175" width="270" height="80" as="geometry" />
</mxCell>
<mxCell id="u4-p3" value="📱  &lt;b&gt;P3 Angeles&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;Telegram + Twilio fallback&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="440" y="280" width="270" height="80" as="geometry" />
</mxCell>
<mxCell id="u4-p4" value="📱  &lt;b&gt;P4 Diego&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;Telegram + Twilio fallback&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="740" y="280" width="270" height="80" as="geometry" />
</mxCell>
<mxCell id="u4-quorum" value="&lt;b&gt;Reglas de quorum&lt;/b&gt;&lt;br/&gt;• Quorum mínimo = &lt;b&gt;2 respuestas concordantes&lt;/b&gt;&lt;br/&gt;• Primera respuesta abre ventana de consolidación de &lt;b&gt;60 s&lt;/b&gt;&lt;br/&gt;• Hard timeout absoluto: &lt;b&gt;180 s&lt;/b&gt; desde creación del incident&lt;br/&gt;• Política split-brain: &lt;b&gt;conservative-wins&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;si 1 approve + 1 reject → block (reject prevalece)&lt;br/&gt;• Two-Person Rule (production-critical):&lt;br/&gt;&amp;nbsp;&amp;nbsp;&lt;b&gt;NO hay auto-execute&lt;/b&gt; en timeout — la inacción cae a block&lt;br/&gt;&amp;nbsp;&amp;nbsp;(diferencia clave vs T2 estándar)" style="text;html=1;align=left;fontSize=11;fontColor=#5f6c7b;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
  <mxGeometry x="1030" y="175" width="590" height="200" as="geometry" />
</mxCell>
<mxCell id="u4-outcomes" value="🎯  Tres outcomes posibles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#999;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
  <mxGeometry x="410" y="400" width="1230" height="200" as="geometry" />
</mxCell>
<mxCell id="u4-out-exec" value="✅  &lt;b&gt;EXECUTE&lt;/b&gt; (2 approves)&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;policy = two_person_approve&lt;br/&gt;Wazuh isolate host&lt;br/&gt;Throttle preventivo → upgrade a isolation completa&lt;br/&gt;Postgres: queries del atacante cortadas&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#16a34a;fontSize=12;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="430" y="450" width="380" height="130" as="geometry" />
</mxCell>
<mxCell id="u4-out-conflict" value="⚠️  &lt;b&gt;BLOCK / conservative-wins&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;policy = conservative_wins&lt;br/&gt;1+ approve y 1+ reject → reject prevalece&lt;br/&gt;Throttle rollback&lt;br/&gt;Notificación al equipo: discrepancia&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fadbd8;strokeColor=#cf272d;fontSize=12;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="830" y="450" width="380" height="130" as="geometry" />
</mxCell>
<mxCell id="u4-out-timeout" value="⏱  &lt;b&gt;BLOCK / no_quorum_timeout&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;policy = no_quorum_timeout&lt;br/&gt;Nadie respondió en 180 s&lt;br/&gt;Throttle rollback (atacante sigue lento)&lt;br/&gt;Two-person: NO escala a auto-isolate&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#b91c1c;fontSize=12;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="1230" y="450" width="390" height="130" as="geometry" />
</mxCell>
<mxCell id="u4-tradeoff" value="&lt;b&gt;Trade-off del Two-Person Rule (intencional):&lt;/b&gt; sacrificas el modo agresivo &lt;i&gt;&quot;si nadie responde isolate igual&quot;&lt;/i&gt; a cambio de evitar que un timeout aísle un activo crítico por accidente.&lt;br/&gt;Mitigación de daño durante la ventana: el throttle preventivo aplicado a t=0 limita queries por segundo del atacante — &lt;b&gt;el daño se acota aún si nadie responde&lt;/b&gt;." style="text;html=1;align=center;fontSize=11;fontColor=#5f6c7b;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
  <mxGeometry x="410" y="615" width="1230" height="60" as="geometry" />
</mxCell>
