  <mxGeometry relative="1" as="geometry" />
</mxCell>
<mxCell id="u6-legend" value="📖  Leyenda · Reglas · Timers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#999;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
  <mxGeometry x="720" y="100" width="920" height="770" as="geometry" />
</mxCell>
<mxCell id="u6-leg-1" value="&lt;b&gt;MITRE ATT&amp;CK&lt;/b&gt;&lt;br/&gt;• &lt;b&gt;T1498&lt;/b&gt; Network Denial of Service (SYN flood, hping3)&lt;br/&gt;• &lt;b&gt;T1499&lt;/b&gt; Endpoint Denial of Service (slow HTTP, slowhttptest)&lt;br/&gt;• &lt;b&gt;T1498.001&lt;/b&gt; Reflection Amplification (variantes futuras)" style="text;html=1;align=left;fontSize=11;fontColor=#333;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
  <mxGeometry x="740" y="140" width="880" height="90" as="geometry" />
</mxCell>
<mxCell id="u6-leg-2" value="&lt;b&gt;Severity &amp; Tier asignados&lt;/b&gt;&lt;br/&gt;• &lt;b&gt;Severity:&lt;/b&gt; HIGH (servicio degradado, no comprometido)&lt;br/&gt;• &lt;b&gt;Tier:&lt;/b&gt; T1 (acción automática reversible — no isolate completo)" style="text;html=1;align=left;fontSize=11;fontColor=#333;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
  <mxGeometry x="740" y="235" width="880" height="80" as="geometry" />
</mxCell>
<mxCell id="u6-leg-3" value="&lt;b&gt;¿Por qué T1 y no T0?&lt;/b&gt;&lt;br/&gt;• Las técnicas T1498/T1499 &lt;b&gt;NO&lt;/b&gt; están en &lt;tt&gt;AUTO_T0_TECHNIQUES&lt;/tt&gt;&lt;br/&gt;• Solo Layer 1 firing → num_layers = 1 (no hay boost por consenso)&lt;br/&gt;• Severity = HIGH → mapea a T1, no a T0&lt;br/&gt;• Las acciones T1 son &lt;b&gt;reversibles&lt;/b&gt; (rate-limit, iptables DROP)&lt;br/&gt;• Si el atacante deja de generar tráfico, la regla expira y todo vuelve normal" style="text;html=1;align=left;fontSize=11;fontColor=#333;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
  <mxGeometry x="740" y="320" width="880" height="140" as="geometry" />
</mxCell>
<mxCell id="u6-leg-4" value="&lt;b&gt;Timers / Reglas que NO aplican&lt;/b&gt;&lt;br/&gt;• Ventana 60s consolidación: &lt;b&gt;no aplica&lt;/b&gt; (no hay HITL)&lt;br/&gt;• Timeout 180s: &lt;b&gt;no aplica&lt;/b&gt;&lt;br/&gt;• Twilio voz: &lt;b&gt;no aplica&lt;/b&gt;&lt;br/&gt;• Two-Person: &lt;b&gt;no aplica&lt;/b&gt; (acción es reversible, no irrevocable)" style="text;html=1;align=left;fontSize=11;fontColor=#333;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
  <mxGeometry x="740" y="465" width="880" height="110" as="geometry" />
</mxCell>
<mxCell id="u6-leg-5" value="&lt;b&gt;Reglas que SÍ aplican&lt;/b&gt;&lt;br/&gt;• &lt;b&gt;Auto-rollback&lt;/b&gt; del rate-limit: 5 min sin nueva detección → desactiva regla iptables&lt;br/&gt;• Si el flood se reanuda → vuelve a disparar T1 (idempotente)&lt;br/&gt;• Si en algún momento sube a 3 capas (DDoS + escaneo + intento de exfil) → boost a T0" style="text;html=1;align=left;fontSize=11;fontColor=#333;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
  <mxGeometry x="740" y="580" width="880" height="110" as="geometry" />
</mxCell>
<mxCell id="u6-leg-6" value="&lt;b&gt;SLA esperado&lt;/b&gt;&lt;br/&gt;• Latencia ataque → detection Sigma red: ≤ 12 s (depende de threshold de tasa)&lt;br/&gt;• Latencia detection → Tier T1: ≤ 3 s&lt;br/&gt;• Latencia tier → rate-limit aplicado: ≤ 10 s&lt;br/&gt;• &lt;b&gt;Total p95: ≤ 25 segundos&lt;/b&gt;  ·  servicio recupera disponibilidad inmediatamente" style="text;html=1;align=left;fontSize=11;fontColor=#333;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
  <mxGeometry x="740" y="695" width="880" height="110" as="geometry" />
</mxCell>
  </root>
</mxGraphModel>
</diagram>
<diagram id="uc-07" name="UC-07 SELECT FP">
<mxGraphModel dx="1700" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1000" math="0" shadow="0">
  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />
<mxCell id="title" value="UC-07 — SELECT masivo benigno · false positive con HITL cancellation" style="text;html=1;align=center;fontSize=22;fontStyle=1;fontColor=#0a3d62;" vertex="1" parent="1">
  <mxGeometry x="380" y="15" width="940" height="32" as="geometry" />
</mxCell>
<mxCell id="subtitle" value="Analista legítima ejecuta SELECT 200k filas a las 3 AM · ML lo confunde con exfiltración · aprobadores cancelan la contención" style="text;html=1;align=center;fontSize=11;fontColor=#5f6c7b;fontStyle=2;" vertex="1" parent="1">
  <mxGeometry x="380" y="50" width="940" height="22" as="geometry" />
</mxCell>
<mxCell id="u7-1" value="👤  &lt;b&gt;Analista legítima&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;user=analyst@empresa&lt;br/&gt;3:14 AM (horario no laboral)&lt;br/&gt;query: SELECT * FROM payroll&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="80" y="100" width="280" height="90" as="geometry" />
</mxCell>
<mxCell id="u7-2" value="⭐  &lt;b&gt;PostgreSQL :5432&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;app_prod · production-critical&lt;br/&gt;query devuelve ~200k filas&lt;br/&gt;pgAudit registra evento READ&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="80" y="220" width="280" height="90" as="geometry" />
</mxCell>
<mxCell id="u7-3" value="🧠🛡️  &lt;b&gt;Detection (Layer 1 + 2)&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;Sigma: pg_select_massive_unusual_table&lt;br/&gt;ML: rows_returned outlier + hora atípica&lt;br/&gt;technique = T1078 (Valid Accounts)&lt;br/&gt;num_layers = 2 · confidence = 0.72&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="80" y="340" width="280" height="110" as="geometry" />
</mxCell>
<mxCell id="u7-4" value="⚙️  &lt;b&gt;SOAR → Tier T2 (two-person)&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;target = production-critical → two-person rule&lt;br/&gt;⚠️ &lt;b&gt;Throttle preventivo aplicado&lt;/b&gt;&lt;br/&gt;query del analista &lt;i&gt;ralentizada&lt;/i&gt; (NO bloqueada)&lt;br/&gt;LLM Triage prepara contexto explicativo&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="80" y="480" width="280" height="110" as="geometry" />
</mxCell>
<mxCell id="u7-5" value="🔔  Telegram + Discord a 4 aprobadores&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;mensaje incluye LLM context:&lt;br/&gt;&quot;User=analyst, hora_inusual, tabla=payroll, posiblemente reporte mensual&quot;&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="80" y="620" width="280" height="70" as="geometry" />
</mxCell>
<mxCell id="u7-llm" value="🧠  Layer 4 — LLM Triage genera contexto que llega a los aprobadores" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3fdf3;strokeColor=#16a34a;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
  <mxGeometry x="410" y="100" width="1230" height="290" as="geometry" />
</mxCell>
<mxCell id="u7-llm-text" value="&lt;b&gt;Prompt LLM (OpenAI gpt-4o-mini con RAG):&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;Event context: user='analyst', SQL='SELECT * FROM payroll', rows=200_456, time='3:14 AM',&lt;br/&gt;&amp;nbsp;&amp;nbsp;source_ip=internal, target_table=payroll&lt;br/&gt;&amp;nbsp;&amp;nbsp;Historical context (vector DB): user 'analyst' ejecuta queries similares cada último viernes del mes&lt;br/&gt;&lt;br/&gt;&lt;b&gt;LLM verdict (incluido en el mensaje al aprobador):&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&#39;color:#15803d&#39;&gt;{ &quot;label&quot;: &quot;benign&quot;, &quot;confidence&quot;: 0.81,&lt;/span&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;&lt;span style=&#39;color:#15803d&#39;&gt;&amp;nbsp;&amp;nbsp;&quot;reasoning&quot;: &quot;Pattern matches monthly payroll report. User has consistent access. No data exfil signals.&quot; }&lt;/span&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Decisión humana esperada:&lt;/b&gt; reject (cancelar contención) — el throttle se libera, la analista termina su query." style="text;html=1;align=left;fontSize=11;fontColor=#333;spacingLeft=8;spacingRight=8;verticalAlign=top;spacingTop=4;" vertex="1" parent="1">
  <mxGeometry x="430" y="140" width="1190" height="230" as="geometry" />
</mxCell>
<mxCell id="u7-outcomes" value="🎯  Outcomes posibles (orden de probabilidad)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#999;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
  <mxGeometry x="410" y="405" width="1230" height="270" as="geometry" />
</mxCell>
<mxCell id="u7-out-reject" value="✅  &lt;b&gt;BLOCK / two_person_reject&lt;/b&gt; (escenario ideal)&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;2 aprobadores leen el LLM context, reconocen patrón mensual, presionan [Reject]&lt;br/&gt;Throttle rollback inmediato&lt;br/&gt;Analista termina su query (con 5-10s extra de latencia)&lt;br/&gt;Audit log marca el evento como false_positive=true&lt;br/&gt;Feedback loop: ML re-entrena con este caso&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#16a34a;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="430" y="450" width="380" height="200" as="geometry" />
</mxCell>
<mxCell id="u7-out-conflict" value="⚠️  &lt;b&gt;BLOCK / conservative-wins&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;1 approve + 1 reject (discrepancia)&lt;br/&gt;Conservative-wins → reject prevalece&lt;br/&gt;Throttle rollback&lt;br/&gt;Mismo resultado que BLOCK pero log con flag &quot;disagreement&quot;&lt;br/&gt;Sirve para post-mortem: ¿quién aprobó? entrenar mejor&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fadbd8;strokeColor=#cf272d;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="830" y="450" width="380" height="200" as="geometry" />
</mxCell>
<mxCell id="u7-out-timeout" value="⏱  &lt;b&gt;BLOCK / no_quorum_timeout&lt;/b&gt; (peor caso pero seguro)&lt;br/&gt;&lt;span style=&#39;font-size:10px&#39;&gt;Nadie respondió en 180 s (3 AM, todos dormidos)&lt;br/&gt;Two-person rule: NO auto-escala a isolate&lt;br/&gt;Throttle rollback automático&lt;br/&gt;Analista pierde 3 minutos de productividad&lt;br/&gt;Por eso Twilio voz a t=60s: para despertar a alguien&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#b91c1c;fontSize=11;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="1230" y="450" width="390" height="200" as="geometry" />
</mxCell>
<mxCell id="u7-out-bad" value="❌  &lt;b&gt;Outcome catastrófico evitado:&lt;/b&gt; si esto fuera T2 estándar (NO two-person), un timeout sin respuesta a los 180s habría &lt;b&gt;auto-aislado&lt;/b&gt; el host de la analista — productividad mensual perdida. La two-person rule existe precisamente para casos como este." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#b91c1c;fontSize=12;align=center;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
  <mxGeometry x="80" y="700" width="1560" height="70" as="geometry" />
</mxCell>
