  <mxGeometry relative="1" as="geometry" />
</mxCell>
<mxCell id="u6-e2" value="Wazuh agent" style="endArrow=classic;html=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#d79b00;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="u6-2" target="u6-3">
  <mxGeometry relative="1" as="geometry" />
